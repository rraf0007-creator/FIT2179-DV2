{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data/country_treemap.csv"
  },
  "transform": [
    {
      "calculate": "datum.share >= 0.03 || datum.country == 'Other countries' ? datum.country : ''",
      "as": "display_country"
    },
    {
      "calculate": "datum.share >= 0.03 || datum.country == 'Other countries' ? format(datum.share, '.1%') : ''",
      "as": "display_share"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "x0",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100]
          },
          "axis": null
        },
        "x2": {
          "field": "x1"
        },
        "y": {
          "field": "y0",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100],
            "reverse": true
          },
          "axis": null
        },
        "y2": {
          "field": "y1"
        },
        "color": {
          "field": "country",
          "type": "nominal",
          "legend": null
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "students",
            "type": "quantitative",
            "title": "Students",
            "format": ","
          },
          {
            "field": "share",
            "type": "quantitative",
            "title": "Share of total",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontWeight": "bold",
        "fontSize": 13,
        "dy": -8
      },
      "encoding": {
        "x": {
          "field": "x_mid",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100]
          },
          "axis": null
        },
        "y": {
          "field": "y_mid",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100],
            "reverse": true
          },
          "axis": null
        },
        "text": {
          "field": "display_country"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 11,
        "dy": 9
      },
      "encoding": {
        "x": {
          "field": "x_mid",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100]
          },
          "axis": null
        },
        "y": {
          "field": "y_mid",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100],
            "reverse": true
          },
          "axis": null
        },
        "text": {
          "field": "display_share"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}