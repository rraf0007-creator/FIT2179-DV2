{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 480,
  "height": 320,
  "data": {
    "url": "data/students_by_country.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": "-x",
      "title": "Source country"
    },
    "x": {
      "field": "students",
      "type": "quantitative",
      "title": "Number of students"
    },
    "tooltip": [
      {
        "field": "country",
        "type": "nominal",
        "title": "Country"
      },
      {
        "field": "students",
        "type": "quantitative",
        "title": "Students",
        "format": ","
      }
    ]
  }
}