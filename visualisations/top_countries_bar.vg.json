{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "A small group of Asian countries dominates Australia’s source-country ranking",
    "subtitle": "International student enrolments by source country, January 2026 YTD"
  },
  "data": {
    "url": "data/students_by_country.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "color": "#2f6f88"
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": [
            "China",
            "India",
            "Nepal",
            "Vietnam",
            "Bangladesh",
            "Philippines",
            "Indonesia",
            "Colombia",
            "Pakistan",
            "Sri Lanka"
          ],
          "title": "Source country"
        },
        "x": {
          "field": "students",
          "type": "quantitative",
          "title": "Number of students",
          "axis": {
            "format": ",.0f"
          }
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "students",
            "type": "quantitative",
            "title": "Students",
            "format": ","
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 11,
        "color": "#111827"
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": [
            "China",
            "India",
            "Nepal",
            "Vietnam",
            "Bangladesh",
            "Philippines",
            "Indonesia",
            "Colombia",
            "Pakistan",
            "Sri Lanka"
          ]
        },
        "x": {
          "field": "students",
          "type": "quantitative"
        },
        "text": {
          "field": "students",
          "type": "quantitative",
          "format": ","
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.country == 'China'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "dx": -8,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "white"
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": [
            "China",
            "India",
            "Nepal",
            "Vietnam",
            "Bangladesh",
            "Philippines",
            "Indonesia",
            "Colombia",
            "Pakistan",
            "Sri Lanka"
          ]
        },
        "x": {
          "field": "students",
          "type": "quantitative"
        },
        "text": {
          "value": "Largest source country"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.country == 'Bangladesh'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 50,
        "fontSize": 11,
        "color": "#374151"
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": [
            "China",
            "India",
            "Nepal",
            "Vietnam",
            "Bangladesh",
            "Philippines",
            "Indonesia",
            "Colombia",
            "Pakistan",
            "Sri Lanka"
          ]
        },
        "x": {
          "field": "students",
          "type": "quantitative"
        },
        "text": {
          "value": "South Asia is strongly represented"
        }
      }
    }
  ],
  "config": {
    "font": "IBM Plex Sans, Arial, sans-serif",
    "title": {
      "font": "IBM Plex Sans, Arial, sans-serif",
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "axis": {
      "labelFont": "IBM Plex Sans, Arial, sans-serif",
      "titleFont": "IBM Plex Sans, Arial, sans-serif"
    },
    "view": {
      "stroke": null
    }
  }
}