{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "Student migration flows recovered sharply after the border closure period",
    "subtitle": "ABS overseas migrant arrivals and departures for student visas, Australia, 2004-05 to 2024-25",
    "font": "IBM Plex Sans",
    "subtitleFont": "IBM Plex Sans",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "anchor": "middle"
  },
  "layer": [
    {
      "data": {
        "values": [
          { "y": 0 }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#6b7280",
        "strokeDash": [4, 4],
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "field": "y",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "url": "data/abs_student_migration_trend_long.csv"
      },
      "mark": {
        "type": "bar",
        "opacity": 0.75
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal",
          "title": "Financial year",
          "axis": {
            "labelAngle": -45,
            "labelFont": "IBM Plex Sans",
            "titleFont": "IBM Plex Sans"
          }
        },
        "y": {
          "field": "signed_value",
          "type": "quantitative",
          "title": "Migrants",
          "axis": {
            "format": ",",
            "labelExpr": "abs(datum.value)",
            "labelFont": "IBM Plex Sans",
            "titleFont": "IBM Plex Sans"
          }
        },
        "color": {
          "field": "direction",
          "type": "nominal",
          "title": "Flow",
          "scale": {
            "domain": ["Arrivals", "Departures"],
            "range": ["#2f6f9f", "#d55e5e"]
          }
        },
        "tooltip": [
          {
            "field": "financial_year",
            "type": "ordinal",
            "title": "Financial year"
          },
          {
            "field": "direction",
            "type": "nominal",
            "title": "Flow"
          },
          {
            "field": "value",
            "type": "quantitative",
            "title": "Migrants",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/abs_student_migration_trend.csv"
      },
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 3,
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal"
        },
        "y": {
          "field": "net_student_migration",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "financial_year",
            "type": "ordinal",
            "title": "Financial year"
          },
          {
            "field": "net_student_migration",
            "type": "quantitative",
            "title": "Net student migration",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "financial_year": "2020-21",
            "net_student_migration": -60680,
            "label": "2020-21: border closures pushed net student migration below zero"
          }
        ]
      },
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90,
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal"
        },
        "y": {
          "field": "net_student_migration",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "financial_year": "2020-21",
            "net_student_migration": -60680,
            "label": "Net migration below zero during border closures"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "dy": 26,
        "font": "IBM Plex Sans",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal"
        },
        "y": {
          "field": "net_student_migration",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "financial_year": "2022-23",
            "net_student_migration": 262270,
            "label": "2022-23: strongest rebound after reopening"
          }
        ]
      },
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90,
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal"
        },
        "y": {
          "field": "net_student_migration",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "financial_year": "2022-23",
            "net_student_migration": 262270,
            "label": "Rebound peak after borders reopened"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "dy": -16,
        "font": "IBM Plex Sans",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal"
        },
        "y": {
          "field": "net_student_migration",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "font": "IBM Plex Sans, Arial, sans-serif",
    "legend": {
      "orient": "bottom",
      "labelFont": "IBM Plex Sans",
      "titleFont": "IBM Plex Sans"
    },
    "view": {
      "stroke": null
    }
  }
}
