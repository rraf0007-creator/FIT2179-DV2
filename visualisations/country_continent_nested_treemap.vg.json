{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 520,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "left": 4,
    "right": 4,
    "top": 10,
    "bottom": 4
  },
  "layer": [
    {
      "data": {
        "url": "data/country_continent_nested_treemap.csv"
      },
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "x0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "x2": {
          "field": "x1"
        },
        "y": {
          "field": "y0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ],
            "reverse": true
          },
          "axis": null
        },
        "y2": {
          "field": "y1"
        },
        "color": {
          "field": "continent",
          "type": "nominal",
          "legend": {
            "title": "Continent"
          },
          "scale": {
            "domain": [
              "Asia",
              "Americas",
              "Europe",
              "Africa",
              "Oceania"
            ],
            "range": [
              "#e69538",
              "#5f7daa",
              "#8bb8b3",
              "#73a65b",
              "#b17aa6"
            ]
          }
        },
        "opacity": {
          "value": 0.92
        },
        "tooltip": [
          {
            "field": "continent",
            "type": "nominal",
            "title": "Continent"
          },
          {
            "field": "country",
            "type": "nominal",
            "title": "Country / group"
          },
          {
            "field": "students",
            "type": "quantitative",
            "title": "Students",
            "format": ","
          },
          {
            "field": "share_total",
            "type": "quantitative",
            "title": "Share of all students",
            "format": ".1%"
          },
          {
            "field": "share_continent",
            "type": "quantitative",
            "title": "Share within continent",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/continent_nested_treemap_boundaries.csv"
      },
      "mark": {
        "type": "rect",
        "fill": null,
        "stroke": "#173b6d",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "x0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "x2": {
          "field": "x1"
        },
        "y": {
          "field": "y0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ],
            "reverse": true
          },
          "axis": null
        },
        "y2": {
          "field": "y1"
        }
      }
    },
    {
      "data": {
        "url": "data/continent_nested_treemap_boundaries.csv"
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "dx": 4,
        "dy": 4,
        "fontWeight": "bold",
        "fontSize": 12,
        "fill": "#173b6d"
      },
      "encoding": {
        "x": {
          "field": "x0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "y": {
          "field": "y0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ],
            "reverse": true
          },
          "axis": null
        },
        "text": {
          "field": "continent_label"
        }
      }
    },
    {
      "data": {
        "url": "data/country_continent_nested_treemap.csv"
      },
      "mark": {
        "type": "text",
        "fontWeight": "bold",
        "fontSize": 11,
        "fill": "#121212",
        "limit": 92
      },
      "encoding": {
        "x": {
          "field": "x_mid",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "y": {
          "field": "y_mid",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ],
            "reverse": true
          },
          "axis": null
        },
        "text": {
          "field": "label_main"
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country / group"
          },
          {
            "field": "students",
            "type": "quantitative",
            "title": "Students",
            "format": ","
          },
          {
            "field": "share_total",
            "type": "quantitative",
            "title": "Share of all students",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/country_continent_nested_treemap.csv"
      },
      "transform": [
        {
          "filter": "datum.label_pct != ''"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 10,
        "dy": 13,
        "fill": "#121212"
      },
      "encoding": {
        "x": {
          "field": "x_mid",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "y": {
          "field": "y_mid",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ],
            "reverse": true
          },
          "axis": null
        },
        "text": {
          "field": "label_pct"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial"
  }
}