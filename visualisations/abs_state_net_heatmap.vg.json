{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 560,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "params": [
    {
      "name": "selectedYear",
      "value": 2024,
      "bind": {
        "input": "range",
        "min": 2004,
        "max": 2024,
        "step": 1,
        "name": "Financial year start: "
      }
    }
  ],
  "title": {
    "text": "Net student migration per 100,000 residents",
    "subtitle": "Population-normalised choropleth. Example: 2024 means 2024–25."
  },
  "data": {
    "url": "data/abs_state_choropleth.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "calculate": "datum.properties.state_code",
      "as": "state_code"
    },
    {
      "calculate": "datum.properties.state",
      "as": "state"
    },
    {
      "calculate": "datum.properties.label_x",
      "as": "label_x"
    },
    {
      "calculate": "datum.properties.label_y",
      "as": "label_y"
    },
    {
      "calculate": "datum.state_code == 'VIC' ? datum.label_x - 250 : datum.label_x",
      "as": "label_x_adjusted"
    },
    {
      "calculate": "datum.state_code == 'VIC' ? datum.label_y - 250 : datum.label_y",
      "as": "label_y_adjusted"
    },
    {
      "calculate": "datum.properties['financial_year_' + selectedYear]",
      "as": "financial_year"
    },
    {
      "calculate": "datum.properties['arrivals_' + selectedYear]",
      "as": "student_arrivals"
    },
    {
      "calculate": "datum.properties['departures_' + selectedYear]",
      "as": "student_departures"
    },
    {
      "calculate": "datum.properties['net_' + selectedYear]",
      "as": "net_student_migration"
    },
    {
      "calculate": "datum.state_code == 'NSW' ? 8624500 : datum.state_code == 'VIC' ? 7104300 : datum.state_code == 'QLD' ? 5692600 : datum.state_code == 'SA' ? 1908200 : datum.state_code == 'WA' ? 3061700 : datum.state_code == 'TAS' ? 576700 : datum.state_code == 'NT' ? 265500 : datum.state_code == 'ACT' ? 486200 : null",
      "as": "state_population"
    },
    {
      "calculate": "datum.net_student_migration / datum.state_population * 100000",
      "as": "net_student_migration_per_100k"
    },
    {
      "filter": "datum.state_code != 'ACT'"
    }
  ],
  "projection": {
    "type": "identity",
    "reflectY": true,
    "scale": 0.055,
    "translate": [70, 560]
  },
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "shape": {
          "field": "geometry",
          "type": "geojson"
        },
        "color": {
          "field": "net_student_migration_per_100k",
          "type": "quantitative",
          "title": "Net student migration per 100,000 residents",
          "scale": {
            "scheme": "blueorange",
            "domain": [-400, 1100],
            "domainMid": 0
          },
          "legend": {
            "format": ",.0f"
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "financial_year",
            "type": "ordinal",
            "title": "Financial year"
          },
          {
            "field": "student_arrivals",
            "type": "quantitative",
            "title": "Student arrivals",
            "format": ","
          },
          {
            "field": "student_departures",
            "type": "quantitative",
            "title": "Student departures",
            "format": ","
          },
          {
            "field": "net_student_migration",
            "type": "quantitative",
            "title": "Net student migration",
            "format": ","
          },
          {
            "field": "state_population",
            "type": "quantitative",
            "title": "State population used",
            "format": ","
          },
          {
            "field": "net_student_migration_per_100k",
            "type": "quantitative",
            "title": "Net per 100,000 residents",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "fill": "#111827"
      },
      "encoding": {
        "longitude": {
          "field": "label_x_adjusted",
          "type": "quantitative"
        },
        "latitude": {
          "field": "label_y_adjusted",
          "type": "quantitative"
        },
        "text": {
          "field": "state_code",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "font": "IBM Plex Sans, Arial, sans-serif",
    "title": {
      "font": "IBM Plex Sans, Arial, sans-serif",
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "legend": {
      "labelFont": "IBM Plex Sans, Arial, sans-serif",
      "titleFont": "IBM Plex Sans, Arial, sans-serif"
    },
    "view": {
      "stroke": null
    }
  }
}