{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
"width": 1200,
"height": 600,
"padding": {
  "left": 130,
  "right": 210,
  "top": 70,
  "bottom": 95
},
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "title": {
    "text": "Where do the largest source countries study in Australia?",
    "subtitle": "Top five source countries plus all other countries, by Australian state/territory, Jan 2026 YTD enrolments",
    "anchor": "middle",
    "fontSize": 16,
    "subtitleFontSize": 14,
    "fontWeight": "bold",
    "subtitleFontWeight": "normal"
  },
  "data": [
    {
  "name": "ribbons",
  "url": "data/country_state_sankey_ribbons.csv",
  "format": {
    "type": "csv",
    "parse": {
      "enrolments": "number",
      "t": "number",
      "x": "number",
      "y_top": "number",
      "y_bottom": "number"
    }
  },
  "transform": [
    {
      "type": "filter",
      "expr": "datum.target !== 'TAS' && datum.target !== 'NT'"
    }
  ]
},
    {
  "name": "nodes",
  "url": "data/country_state_sankey_nodes.csv",
  "format": {
    "type": "csv",
    "parse": {
      "total": "number",
      "x0": "number",
      "x1": "number",
      "y0": "number",
      "y1": "number",
      "x_label": "number",
      "y_label": "number"
    }
  },
  "transform": [
    {
      "type": "filter",
      "expr": "datum.state_code !== 'TAS' && datum.state_code !== 'NT'"
    }
  ]
},
    {
      "name": "sourceLabels",
      "source": "nodes",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.side === 'source'"
        }
      ]
    },
    {
      "name": "targetLabels",
      "source": "nodes",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.side === 'target'"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "x",
      "type": "linear",
      "domain": [-0.16, 1.18],
      "range": "width"
    },
    {
      "name": "y",
      "type": "linear",
      "domain": [0, 1],
      "range": "height"
    },
    {
      "name": "sourceColor",
      "type": "ordinal",
      "domain": [
        "Bangladesh",
        "China",
        "India",
        "Nepal",
        "Other countries",
        "Vietnam"
      ],
      "range": [
        "#0b2545",
        "#2f6f88",
        "#7a9e9f",
        "#d88c4a",
        "#c8553d",
        "#9ca3af"
      ]
    }
  ],
"legends": [
  {
    "fill": "sourceColor",
    "title": "Source country",
    "orient": "bottom",
    "direction": "horizontal",
    "symbolType": "square",
    "symbolSize": 140,
    "labelFontSize": 12,
    "titleFontSize": 13
  }
],
  "marks": [
    {
      "type": "group",
      "from": {
        "facet": {
          "name": "flow",
          "data": "ribbons",
          "groupby": "flow_id"
        }
      },
      "marks": [
        {
          "type": "area",
          "from": {
            "data": "flow"
          },
          "sort": {
            "field": "datum.t",
            "order": "ascending"
          },
          "encode": {
            "enter": {
              "interpolate": {
                "value": "monotone"
              },
              "x": {
                "scale": "x",
                "field": "x"
              },
              "y": {
                "scale": "y",
                "field": "y_top"
              },
              "y2": {
                "scale": "y",
                "field": "y_bottom"
              },
              "fill": {
                "scale": "sourceColor",
                "field": "source"
              },
              "fillOpacity": {
                "value": 0.55
              },
              "tooltip": {
                "signal": "datum.source + ' → ' + datum.target_name + ': ' + format(datum.enrolments, ',') + ' enrolments'"
              }
            }
          }
        }
      ]
    },
    {
      "type": "rect",
      "from": {
        "data": "nodes"
      },
      "encode": {
        "enter": {
          "x": {
            "scale": "x",
            "field": "x0"
          },
          "x2": {
            "scale": "x",
            "field": "x1"
          },
          "y": {
            "scale": "y",
            "field": "y0"
          },
          "y2": {
            "scale": "y",
            "field": "y1"
          },
          "fill": {
            "signal": "datum.side === 'source' ? '#12355b' : '#2f6f88'"
          },
          "fillOpacity": {
            "value": 0.98
          },
          "tooltip": {
            "signal": "datum.label + ': ' + format(datum.total, ',') + ' enrolments'"
          }
        }
      }
    },
    {
      "type": "text",
      "from": {
        "data": "sourceLabels"
      },
      "encode": {
        "enter": {
          "x": {
            "scale": "x",
            "field": "x_label"
          },
          "y": {
            "scale": "y",
            "field": "y_label"
          },
          "text": {
            "field": "label"
          },
          "align": {
            "value": "right"
          },
          "baseline": {
            "value": "middle"
          },
          "dx": {
            "value": -8
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "bold"
          },
          "fill": {
            "value": "#111827"
          }
        }
      }
    },
    {
      "type": "text",
      "from": {
        "data": "targetLabels"
      },
      "encode": {
        "enter": {
          "x": {
            "scale": "x",
            "field": "x_label"
          },
          "y": {
            "scale": "y",
            "field": "y_label"
          },
          "text": {
            "field": "label"
          },
          "align": {
            "value": "left"
          },
          "baseline": {
            "value": "middle"
          },
          "dx": {
            "value": 8
          },
          "fontSize": {
            "value": 12
          },
          "fontWeight": {
            "value": "bold"
          },
          "fill": {
            "value": "#111827"
          }
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}