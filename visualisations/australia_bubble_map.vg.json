{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 480,
  "autosize": {
  "type": "fit",
  "contains": "padding"
},
  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 650
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/vega/vega-datasets/master/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {
          "filter": "datum.id == 36"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#e8edf2",
        "stroke": "#6b7280",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "data/state_map_points.csv"
      },
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "size": {
          "field": "students",
          "type": "quantitative",
          "title": "YTD enrolments",
          "scale": {
            "range": [100, 3500]
          }
        },
        "color": {
          "field": "students",
          "type": "quantitative",
          "title": "YTD enrolments",
          "scale": {
            "scheme": "blues"
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "students",
            "type": "quantitative",
            "title": "YTD enrolments",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/state_map_points.csv"
      },
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "dy": -14
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "state_code",
          "type": "nominal"
        }
      }
    }
  ]
}