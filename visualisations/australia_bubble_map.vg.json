{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 520,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "International student enrolments relative to state population",
    "subtitle": "Department of Education enrolments per 100,000 residents, January 2026 YTD"
  },
  "data": {
    "url": "data/abs_state_choropleth.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "calculate": "datum.properties.state_code",
      "as": "state_code"
    },
    {
      "calculate": "datum.properties.state",
      "as": "state"
    },
    {
      "calculate": "datum.properties.label_x",
      "as": "label_x"
    },
    {
      "calculate": "datum.properties.label_y",
      "as": "label_y"
    },
{
  "calculate": "datum.state_code == 'VIC' ? datum.label_x - 250 : datum.state_code == 'SA' ? datum.label_x - 10 : datum.state_code == 'QLD' ? datum.label_x - 420 : datum.state_code == 'NSW' ? datum.label_x - 120 : datum.label_x",
  "as": "label_x_adjusted"
},
{
  "calculate": "datum.state_code == 'VIC' ? datum.label_y - 150 : datum.state_code == 'SA' ? datum.label_y + 625 : datum.state_code == 'QLD' ? datum.label_y - 750 : datum.state_code == 'NSW' ? datum.label_y + 80 : datum.label_y",
  "as": "label_y_adjusted"
},
    {
      "lookup": "state_code",
      "from": {
        "data": {
          "url": "data/students_by_state.csv"
        },
        "key": "state_code",
        "fields": [
          "students"
        ]
      }
    },
    {
      "calculate": "datum.state_code == 'NSW' ? 8624500 : datum.state_code == 'VIC' ? 7104300 : datum.state_code == 'QLD' ? 5692600 : datum.state_code == 'SA' ? 1908200 : datum.state_code == 'WA' ? 3061700 : datum.state_code == 'TAS' ? 576700 : datum.state_code == 'NT' ? 265500 : datum.state_code == 'ACT' ? 486200 : null",
      "as": "state_population"
    },
    {
      "calculate": "datum.students / datum.state_population * 100000",
      "as": "students_per_100k"
    },
    {
      "filter": "datum.state_code != 'ACT'"
    }
  ],
  "projection": {
    "type": "identity",
    "reflectY": true,
    "scale": 0.055,
    "translate": [
      70,
      560
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "shape": {
          "field": "geometry",
          "type": "geojson"
        },
        "color": {
          "field": "students_per_100k",
          "type": "quantitative",
          "title": "Enrolments per 100,000 residents",
          "scale": {
            "scheme": "blues",
            "domain": [
              0,
              3000
            ]
          },
          "legend": {
            "format": ",.0f"
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "state_code",
            "type": "nominal",
            "title": "Code"
          },
          {
            "field": "students",
            "type": "quantitative",
            "title": "January 2026 YTD enrolments",
            "format": ","
          },
          {
            "field": "state_population",
            "type": "quantitative",
            "title": "State population used",
            "format": ","
          },
          {
            "field": "students_per_100k",
            "type": "quantitative",
            "title": "Enrolments per 100,000 residents",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "fill": "#111827"
      },
      "encoding": {
        "longitude": {
          "field": "label_x_adjusted",
          "type": "quantitative"
        },
        "latitude": {
          "field": "label_y_adjusted",
          "type": "quantitative"
        },
        "text": {
          "field": "state",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state_code == 'VIC'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "dx": -28,
        "dy": 30,
        "fontSize": 12,
        "lineBreak": "\n",
        "color": "#374151"
      },
      "encoding": {
        "longitude": {
          "field": "label_x_adjusted",
          "type": "quantitative"
        },
        "latitude": {
          "field": "label_y_adjusted",
          "type": "quantitative"
        },
        "text": {
          "value": "Victoria remains a major study destination\neven after adjusting for population"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state_code == 'NSW'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 70,
        "dy": 0,
        "fontSize": 12,
        "fontWeight": "bold",
        "lineBreak": "\n",
        "color": "#12355b"
      },
      "encoding": {
        "longitude": {
          "field": "label_x_adjusted",
          "type": "quantitative"
        },
        "latitude": {
          "field": "label_y_adjusted",
          "type": "quantitative"
        },
        "text": {
          "value": "NSW has the largest raw enrolment total,\nbut the colour now shows population-adjusted intensity"
        }
      }
    }
  ],
  "config": {
    "font": "IBM Plex Sans, Arial, sans-serif",
    "title": {
      "font": "IBM Plex Sans, Arial, sans-serif",
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "legend": {
      "labelFont": "IBM Plex Sans, Arial, sans-serif",
      "titleFont": "IBM Plex Sans, Arial, sans-serif"
    },
    "view": {
      "stroke": null
    }
  }
}