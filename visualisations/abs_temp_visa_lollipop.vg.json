{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "Student visas were the largest temporary visa migrant arrival group in 2024–25",
    "subtitle": "ABS overseas migrant arrivals by selected temporary visa type"
  },
  "data": {
    "url": "data/abs_temp_visa_arrivals_2024_25.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "visa_type",
      "type": "nominal",
      "sort": "-x",
      "title": "Temporary visa type"
    },
    "x": {
      "field": "arrivals",
      "type": "quantitative",
      "title": "Migrant arrivals",
      "axis": {
        "format": ",.0f"
      }
    },
    "color": {
      "condition": {
        "test": "datum.visa_type == 'Student'",
        "value": "#d55e5e"
      },
      "value": "#9ca3af"
    },
    "tooltip": [
      {
        "field": "visa_type",
        "type": "nominal",
        "title": "Visa type"
      },
      {
        "field": "arrivals",
        "type": "quantitative",
        "title": "Arrivals",
        "format": ","
      },
      {
        "field": "departures",
        "type": "quantitative",
        "title": "Departures",
        "format": ","
      },
      {
        "field": "net",
        "type": "quantitative",
        "title": "Net migration",
        "format": ","
      }
    ]
  },
  "config": {
    "legend": {
      "disable": true
    }
  }
}